; Track Scoreboard Script v5 with Layout Switching and Splits
; Each athlete is sent as a separate complete JSON object
; Includes ResulTV-style Command=LayoutDraw commands for automatic layout switching
; Added: Cumulative Split (CS), Last Split (LS), Laps To Go (L2G)
;
;      \11  Time
;         \00  No variable
;         \01  Formatted time
;      \13  Results Header/Trailer
;         \00  No variable
;         \01  OFFICIAL/UNOFFICIAL string
;         \02  Event name (Display Name)
;         \03  Wind
;         \04  Event number
;         \05  Round number
;         \06  Heat number
;         \07  AUTO/MANUAL start type
;         \08  Number of participants
;         \09  ARMED/RUNNING status
;         \0a  Distance
;      \14  Result
;         \00  No variable
;         \01  Place
;         \02  Lane
;         \03  Id (Bib)
;         \04  Name
;         \05  Affiliation
;         \06  Time
;         \07  Delta Time
;         \08  Cumulative Split Time
;         \09  Last Split Time
;         \0a  Laps To Go
;         \0b  License
;         \0c  ReacTime
;         \17  First Name
;         \18  Last Name

;;TimeRunning
\11\00Command=LayoutDraw;Name=Running Time;\0a
\11\01{"c":"time","t":"%s"}\0d\0a

;;TimeStopped
\11\00Command=LayoutDraw;Name=Track Results;\0a
\11\01{"c":"stopped","t":"%s"}\0d\0a

;;TimeOfDay
\11\00Command=LayoutDraw;Name=Idle;\0a
\11\01{"c":"tod","t":"%s"}\0d\0a

;;TimeArmed
\11\00Command=LayoutDraw;Name=Start List;\0a
\11\00{"c":"armed"}\0d\0a

;;StartListHeader
\13\00Command=LayoutDraw;Name=Start List;\0a

;;StartList
\14\00{"T":"S","D":{
\13\04"EN":%s,
\13\05"R":%s,
\13\06"H":%s,
\13\01"S":"%s",
\13\0a"DS":"%s",
\13\02"DN":"%s",
\14\01"P":"%s",
\14\02"L":"%s",
\14\03"BIB":"%s",
\14\04"N":"%s",
\14\05"AF":"%s",
\14\17"FN":"%s",
\14\18"LN":"%s"
\14\00}}\0d\0a

;;StartListTrailer

;;StartedHeader
\13\00Command=LayoutDraw;Name=Running;\0a

;;Started
\14\00{"T":"T","D":{
\13\04"EN":%s,
\13\05"R":%s,
\13\06"H":%s,
\13\01"S":"%s",
\13\0a"DS":"%s",
\13\02"DN":"%s",
\13\03"W":"%s",
\14\01"P":"%s",
\14\02"L":"%s",
\14\03"BIB":"%s",
\14\04"N":"%s",
\14\05"AF":"%s",
\14\06"T":"%s",
\14\0c"RT":"%s",
\14\0a"L2G":"%s",
\14\08"CS":"%s",
\14\09"LS":"%s",
\14\17"FN":"%s",
\14\18"LN":"%s"
\14\00}}\0d\0a

;;StartedTrailer

;;ResultsHeader
\13\00Command=LayoutDraw;Name=Results;\0a

;;Results
\14\00{"T":"T","D":{
\13\04"EN":%s,
\13\05"R":%s,
\13\06"H":%s,
\13\01"S":"%s",
\13\0a"DS":"%s",
\13\02"DN":"%s",
\13\03"W":"%s",
\14\01"P":"%s",
\14\02"L":"%s",
\14\03"BIB":"%s",
\14\04"N":"%s",
\14\05"AF":"%s",
\14\06"T":"%s",
\14\0c"RT":"%s",
\14\0a"L2G":"%s",
\14\08"CS":"%s",
\14\09"LS":"%s",
\14\17"FN":"%s",
\14\18"LN":"%s"
\14\00}}\0d\0a

;;ResultsTrailer



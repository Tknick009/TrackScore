{
  "name": "track-field-scoreboard",
  "version": "1.0.0",
  "description": "Track and Field Stadium Scoreboard - Desktop Application",
  "main": "dist/main.js",
  "author": "Stadium Operations",
  "license": "MIT",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "build:app": "npm run build:main && electron-builder",
    "build:win": "npm run build:main && electron-builder --win",
    "build:mac": "npm run build:main && electron-builder --mac",
    "dev": "tsc -p tsconfig.json && electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "get-port": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.6.3"
  },
  "build": {
    "extends": "./build.config.js"
  }
}
